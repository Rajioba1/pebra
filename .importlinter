[importlinter]
root_package = pebra
include_external_packages = True

# --- The one rule (Architecture §2): core/ imports only pure stdlib + core/ ---

[importlinter:contract:core-no-inner-layers]
name = core never imports inner layers
type = forbidden
source_modules =
    pebra.core
forbidden_modules =
    pebra.ports
    pebra.adapters
    pebra.app
    pebra.cli
    pebra.mcp_server
    pebra.dashboard
    pebra.composition
    pebra.observatory_context

[importlinter:contract:core-no-impure-libs]
name = core forbidden from impure stdlib + heavy libs (Architecture §12)
type = forbidden
source_modules =
    pebra.core
forbidden_modules =
    sqlite3
    subprocess
    argparse
    pandas
    scipy
    matplotlib
    seaborn
    datasets
    pydriller
    swebench
    fastapi
    starlette
    uvicorn
    jinja2
    yaml
    radon
    bandit
    numpy
    sklearn
    mcp

# --- Benchmark wall (Phase 5b): production never imports the benchmark harness ---

[importlinter:contract:pebra-no-benchmarks]
name = production never imports benchmarks
type = forbidden
source_modules =
    pebra
forbidden_modules =
    benchmarks

[importlinter:contract:pebra-no-e2e]
name = production never imports the e2e suite
type = forbidden
source_modules =
    pebra
forbidden_modules =
    e2e

# --- Layer discipline ---

[importlinter:contract:app-no-adapters]
name = app reaches I/O only through ports, never adapters
type = forbidden
source_modules =
    pebra.app
forbidden_modules =
    pebra.adapters
    pebra.composition
    pebra.observatory_context

[importlinter:contract:adapters-only-core-ports]
name = adapters import only core + ports (no app/surfaces)
type = forbidden
source_modules =
    pebra.adapters
forbidden_modules =
    pebra.app
    pebra.cli
    pebra.mcp_server
    pebra.dashboard
    pebra.composition
    pebra.observatory_context

# The dashboard surface may read through the shared Observatory query controller (app), but must never
# reach a mutation/lifecycle controller. New mutation controllers MUST be added to this list.
[importlinter:contract:dashboard-no-mutation-app]
name = dashboard imports only the observatory query controller from app (never mutation controllers)
type = forbidden
source_modules =
    pebra.dashboard
forbidden_modules =
    pebra.app.accept_risk_controller
    pebra.app.assess_controller
    pebra.app.candidate_apply_controller
    pebra.app.finalize_outcome_controller
    pebra.app.human_approval_controller
    pebra.app.learning_controller
    pebra.app.promotion_controller
    pebra.app.record_outcome_controller
    pebra.app.verify_controller

[importlinter:contract:assess-no-learning]
name = assess never imports learning (Hard Rule — Milestone 4: measure, never reapply)
type = forbidden
source_modules =
    pebra.app.assess_controller
    pebra.cli.assess
    pebra.mcp_server
forbidden_modules =
    pebra.app.learning_controller
    pebra.app.promotion_controller
    pebra.core.prediction_error
    pebra.core.learning_eval
    pebra.core.promotion_evaluator
    pebra.adapters.learning_store
    pebra.adapters.calibration_store

[importlinter:contract:layers]
name = layered architecture (surfaces > app > ports > core)
type = layers
layers =
    pebra.cli : pebra.mcp_server
    pebra.app
    pebra.ports
    pebra.core
